<!DOCTYPE html>
<html lang="th">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ใบเสนอราคา - Quotation Generator</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Sarabun:wght@300;400;500;600;700&display=swap');

  :root {
    --orange: #E8711A;
    --orange-light: #F59340;
    --orange-pale: #FFF3E8;
    --dark: #1a1a2e;
    --gray: #6b7280;
    --gray-light: #f3f4f6;
    --border: #e5e7eb;
    --text: #111827;
  }

  * { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    font-family: 'Sarabun', sans-serif;
    background: #f0f0f0;
    color: var(--text);
    font-size: 13px;
    line-height: 1.5;
  }

  /* ===== TOOLBAR ===== */
  .toolbar {
    background: var(--dark);
    padding: 10px 20px;
    display: flex;
    gap: 10px;
    align-items: center;
    flex-wrap: wrap;
    position: sticky;
    top: 0;
    z-index: 100;
    box-shadow: 0 2px 8px rgba(0,0,0,0.3);
  }
  .toolbar-title {
    color: var(--orange-light);
    font-weight: 700;
    font-size: 15px;
    flex: 1;
  }
  .btn {
    padding: 7px 16px;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    font-family: 'Sarabun', sans-serif;
    font-size: 13px;
    font-weight: 600;
    transition: all 0.2s;
    display: inline-flex;
    align-items: center;
    gap: 6px;
  }
  .btn-orange { background: var(--orange); color: #fff; }
  .btn-orange:hover { background: var(--orange-light); transform: translateY(-1px); }
  .btn-outline { background: transparent; color: #fff; border: 1.5px solid #fff3; }
  .btn-outline:hover { background: rgba(255,255,255,0.1); }
  .btn-red { background: #dc2626; color: #fff; }
  .btn-red:hover { background: #b91c1c; }

  /* ===== DOCUMENT WRAPPER ===== */
  .page-wrapper {
    max-width: 900px;
    margin: 24px auto;
    padding: 0 16px;
  }

  /* ===== DOCUMENT ===== */
  #document {
    background: #fff;
    box-shadow: 0 4px 20px rgba(0,0,0,0.12);
    border-radius: 2px;
    padding: 32px 36px;
    position: relative;
    overflow: hidden;
  }

  /* Orange corner decoration */
  #document::before {
    content: '';
    position: absolute;
    top: 0; right: 0;
    width: 0; height: 0;
    border-style: solid;
    border-width: 0 90px 90px 0;
    border-color: transparent var(--orange) transparent transparent;
  }
  #document::after {
    content: '';
    position: absolute;
    top: 0; right: 0;
    width: 0; height: 0;
    border-style: solid;
    border-width: 0 60px 60px 0;
    border-color: transparent var(--orange-light) transparent transparent;
  }

  /* ===== HEADER ===== */
  .doc-header {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 20px;
  }

  /* Logo area */
  .logo-area {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }
  .logo-upload-wrapper {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 4px;
  }
  .logo-img {
    width: 100px;
    height: 70px;
    object-fit: contain;
    cursor: pointer;
  }
  .logo-placeholder {
    width: 100px;
    height: 70px;
    border: 2px dashed var(--border);
    border-radius: 4px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: pointer;
    color: var(--gray);
    font-size: 11px;
    text-align: center;
    background: var(--gray-light);
    transition: border-color 0.2s;
  }
  .logo-placeholder:hover { border-color: var(--orange); color: var(--orange); }
  #logo-input { display: none; }

  .company-info { flex: 1; }
  .editable {
    border: none;
    outline: none;
    width: 100%;
    font-family: 'Sarabun', sans-serif;
    font-size: 13px;
    color: var(--text);
    background: transparent;
    padding: 1px 3px;
    border-radius: 3px;
    transition: background 0.15s;
  }
  .editable:hover { background: var(--orange-pale); }
  .editable:focus { background: #fff8f0; outline: 1.5px solid var(--orange); }
  .company-name { font-size: 15px; font-weight: 700; }
  textarea.editable { resize: none; min-height: 36px; display: block; }

  /* Right header */
  .doc-title-area {
    text-align: center;
  }
  .doc-title {
    font-size: 28px;
    font-weight: 700;
    color: var(--orange);
    margin-bottom: 12px;
    letter-spacing: 1px;
    position: relative;
    z-index: 1;
  }
  .doc-meta-table {
    width: 100%;
    border-collapse: collapse;
  }
  .doc-meta-table td {
    padding: 4px 6px;
    font-size: 13px;
    border-bottom: 1px solid var(--border);
  }
  .doc-meta-table td:first-child {
    color: var(--gray);
    width: 70px;
    white-space: nowrap;
  }
  .doc-meta-table td:last-child { font-weight: 600; }
  .meta-input {
    border: none;
    outline: none;
    font-family: 'Sarabun', sans-serif;
    font-size: 13px;
    font-weight: 600;
    background: transparent;
    width: 100%;
  }
  .meta-input:focus { background: #fff8f0; outline: 1px solid var(--orange); border-radius: 2px; }

  /* Divider */
  .divider {
    height: 2px;
    background: linear-gradient(90deg, var(--orange), var(--orange-light), transparent);
    margin: 14px 0;
  }

  /* ===== CUSTOMER SECTION ===== */
  .customer-label {
    color: var(--orange);
    font-weight: 700;
    font-size: 14px;
    margin-bottom: 4px;
  }
  .customer-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0 20px;
  }
  .field-row {
    display: flex;
    align-items: baseline;
    gap: 4px;
    margin-bottom: 2px;
  }
  .field-label {
    color: var(--gray);
    font-size: 12px;
    white-space: nowrap;
    min-width: 90px;
  }
  .field-input {
    flex: 1;
    border: none;
    border-bottom: 1px dashed var(--border);
    outline: none;
    font-family: 'Sarabun', sans-serif;
    font-size: 13px;
    padding: 1px 4px;
    background: transparent;
    transition: border-color 0.2s, background 0.15s;
  }
  .field-input:focus { border-bottom-color: var(--orange); background: var(--orange-pale); }
  .field-input:hover { background: var(--orange-pale); }

  /* ===== TABLE ===== */
  .items-table {
    width: 100%;
    border-collapse: collapse;
    margin-top: 16px;
    font-size: 13px;
  }
  .items-table thead tr {
    background: var(--orange);
    color: #fff;
  }
  .items-table th {
    padding: 8px 10px;
    text-align: center;
    font-weight: 600;
    font-size: 13px;
  }
  .items-table th:nth-child(2) { text-align: left; }
  .items-table td {
    padding: 6px 10px;
    border-bottom: 1px solid var(--border);
    text-align: center;
    vertical-align: middle;
  }
  .items-table td:nth-child(2) { text-align: left; }
  .items-table tbody tr:nth-child(even) { background: #fafafa; }
  .items-table tbody tr:hover { background: var(--orange-pale); }

  .cell-input {
    border: none;
    outline: none;
    background: transparent;
    font-family: 'Sarabun', sans-serif;
    font-size: 13px;
    text-align: inherit;
    width: 100%;
    padding: 1px 2px;
  }
  .cell-input:focus { background: #fff8f0; outline: 1px solid var(--orange); border-radius: 2px; }
  .cell-input.num { text-align: right; }
  td.amount-cell { font-weight: 600; text-align: right; color: var(--dark); }
  td.seq-cell { color: var(--gray); width: 30px; }

  /* Select for VAT */
  .cell-select {
    border: none; outline: none; background: transparent;
    font-family: 'Sarabun', sans-serif; font-size: 12px;
    cursor: pointer; width: 100%; text-align: center;
  }
  .cell-select:focus { background: #fff8f0; outline: 1px solid var(--orange); border-radius: 2px; }

  .btn-del-row {
    background: none; border: none; cursor: pointer;
    color: #ccc; font-size: 16px; line-height: 1; padding: 0 2px;
    transition: color 0.15s;
  }
  .btn-del-row:hover { color: #dc2626; }

  /* ===== SUMMARY ===== */
  .summary-section {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 10px;
    margin-top: 12px;
    align-items: start;
  }
  .amount-in-words {
    align-self: end;
    font-size: 13px;
    color: var(--gray);
    padding: 0 4px;
  }
  .amount-in-words span { font-weight: 600; color: var(--dark); }

  .summary-table {
    width: 280px;
    border-collapse: collapse;
  }
  .summary-table td {
    padding: 5px 10px;
    font-size: 13px;
  }
  .summary-table td:first-child { color: var(--gray); text-align: right; }
  .summary-table td:last-child { text-align: right; font-weight: 600; min-width: 110px; }
  .summary-table .highlight-row td {
    background: var(--orange);
    color: #fff;
    font-weight: 700;
    font-size: 14px;
    border-radius: 4px;
  }
  .summary-table tr.sub-row td { border-bottom: 1px solid var(--border); }
  .summary-discount { color: var(--orange) !important; }

  /* ===== NOTES & SIGNATURES ===== */
  .notes-section {
    margin-top: 20px;
  }
  .notes-label {
    color: var(--orange);
    font-weight: 700;
    font-size: 13px;
    margin-bottom: 4px;
  }
  .notes-input {
    width: 100%;
    border: 1px dashed var(--border);
    border-radius: 4px;
    padding: 6px 10px;
    font-family: 'Sarabun', sans-serif;
    font-size: 13px;
    min-height: 40px;
    resize: vertical;
    outline: none;
    transition: border-color 0.2s;
  }
  .notes-input:focus { border-color: var(--orange); }

  .sig-section {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 20px;
    margin-top: 36px;
    align-items: end;
  }
  .sig-block { text-align: center; }
  .sig-label { font-size: 12px; color: var(--gray); margin-bottom: 4px; }
  .sig-company { font-size: 13px; font-weight: 600; margin-bottom: 8px; }
  .sig-logo-center {
    width: 100px;
    height: 70px;
    object-fit: contain;
    margin: 0 auto;
    display: block;
  }
  .sig-line {
    border-top: 1.5px solid var(--dark);
    margin-top: 28px;
    margin-bottom: 4px;
  }
  .sig-name-input {
    border: none; outline: none; background: transparent;
    font-family: 'Sarabun', sans-serif; font-size: 12px;
    text-align: center; width: 100%;
  }
  .sig-name-input:focus { background: var(--orange-pale); }
  .sig-date-row {
    display: flex; gap: 4px; align-items: center; justify-content: center;
    font-size: 12px; color: var(--gray); margin-top: 2px;
  }
  .sig-date-input {
    border: none; border-bottom: 1px dashed var(--border); outline: none;
    font-family: 'Sarabun', sans-serif; font-size: 12px;
    width: 90px; text-align: center; background: transparent;
  }
  .sig-date-input:focus { border-bottom-color: var(--orange); background: var(--orange-pale); }

  /* ===== WATERMARK-LIKE FOOTER ===== */
  .doc-footer {
    display: flex;
    justify-content: flex-end;
    margin-top: 16px;
    font-size: 11px;
    color: #ccc;
  }

  /* ===== ADD ROW BUTTON ===== */
  .add-row-wrapper {
    text-align: left;
    margin-top: 6px;
  }

  /* ===== PRINT STYLES ===== */
  @media print {
    body { background: #fff; }
    .toolbar, .add-row-wrapper, .btn-del-row, #logo-input,
    .logo-placeholder { display: none !important; }
    .page-wrapper { margin: 0; padding: 0; max-width: 100%; }
    #document { box-shadow: none; border-radius: 0; padding: 20px 24px; }
    .editable, .cell-input, .field-input, .meta-input, .sig-name-input,
    .sig-date-input, .notes-input, .cell-select {
      border: none !important; background: transparent !important;
      -webkit-print-color-adjust: exact; print-color-adjust: exact;
    }
    @page { size: A4; margin: 10mm 15mm; }
  }
</style>
</head>
<body>

<!-- TOOLBAR -->
<div class="toolbar no-print">
  <div class="toolbar-title">📄 ระบบใบเสนอราคา</div>
  <button class="btn btn-outline" onclick="clearForm()">🗑 ล้างข้อมูลเอกสาร</button>
  <button class="btn btn-outline" onclick="clearCompany()">🏢 ล้างข้อมูลบริษัท</button>
  <button class="btn btn-outline" onclick="addRow()">➕ เพิ่มรายการ</button>
  <button class="btn btn-orange" onclick="savePDF()">💾 บันทึก PDF</button>
  <button class="btn btn-outline" onclick="window.print()">🖨 พิมพ์</button>
</div>

<!-- PAGE -->
<div class="page-wrapper">
<div id="document">

  <!-- HEADER -->
  <div class="doc-header">
    <!-- Left: Logo + Company -->
    <div class="logo-area">
      <div class="logo-upload-wrapper">
        <div id="logo-placeholder" class="logo-placeholder" onclick="document.getElementById('logo-input').click()">
          คลิกเพื่อ<br>อัปโหลดโลโก้
        </div>
        <img id="logo-img" class="logo-img" style="display:none;" onclick="document.getElementById('logo-input').click()" alt="Logo">
        <input type="file" id="logo-input" accept="image/*" onchange="uploadLogo(event)">
      </div>
      <div class="company-info">
        <input class="editable company-name" id="seller-name" placeholder="ชื่อบริษัท / ร้านค้า" value="">
        <textarea class="editable" id="seller-address" placeholder="ที่อยู่บริษัท" rows="2"></textarea>
        <input class="editable" id="seller-tax" placeholder="เลขประจำตัวผู้เสียภาษี">
        <input class="editable" id="seller-phone" placeholder="โทร.">
      </div>
    </div>

    <!-- Right: Title + Meta -->
    <div class="doc-title-area">
      <div class="doc-title">ใบเสนอราคา</div>
      <table class="doc-meta-table">
        <tr>
          <td>เลขที่</td>
          <td><input class="meta-input" id="doc-no" placeholder="QT202600001"></td>
        </tr>
        <tr>
          <td>วันที่</td>
          <td><input class="meta-input" id="doc-date" type="date"></td>
        </tr>
        <tr>
          <td>ผู้ขาย</td>
          <td><input class="meta-input" id="sales-name" placeholder="ชื่อผู้ขาย"></td>
        </tr>
        <tr>
          <td>อ้างอิง</td>
          <td><input class="meta-input" id="doc-ref" placeholder="เอกสารอ้างอิง (ถ้ามี)"></td>
        </tr>
      </table>
    </div>
  </div>

  <div class="divider"></div>

  <!-- CUSTOMER -->
  <div class="customer-label">ลูกค้า</div>
  <div class="customer-grid">
    <div>
      <div class="field-row">
        <span class="field-label">ชื่อลูกค้า/บริษัท</span>
        <input class="field-input" id="cust-name" placeholder="ชื่อลูกค้า">
      </div>
      <div class="field-row">
        <span class="field-label">ที่อยู่</span>
        <input class="field-input" id="cust-address" placeholder="ที่อยู่">
      </div>
      <div class="field-row">
        <span class="field-label">แขวง/ตำบล</span>
        <input class="field-input" id="cust-sub" placeholder="แขวง/ตำบล">
      </div>
      <div class="field-row">
        <span class="field-label">เขต/อำเภอ จังหวัด</span>
        <input class="field-input" id="cust-dist" placeholder="เขต/อำเภอ จังหวัด รหัสไปรษณีย์">
      </div>
    </div>
    <div>
      <div class="field-row">
        <span class="field-label">เลขผู้เสียภาษี</span>
        <input class="field-input" id="cust-tax" placeholder="เลขประจำตัวผู้เสียภาษี">
      </div>
      <div class="field-row">
        <span class="field-label">โทรศัพท์</span>
        <input class="field-input" id="cust-phone" placeholder="เบอร์โทรศัพท์">
      </div>
      <div class="field-row">
        <span class="field-label">อีเมล</span>
        <input class="field-input" id="cust-email" placeholder="อีเมล">
      </div>
      <div class="field-row">
        <span class="field-label">ผู้ติดต่อ</span>
        <input class="field-input" id="cust-contact" placeholder="ชื่อผู้ติดต่อ">
      </div>
    </div>
  </div>

  <!-- ITEMS TABLE -->
  <table class="items-table" id="items-table">
    <thead>
      <tr>
        <th style="width:30px">#</th>
        <th style="min-width:200px">รายละเอียด</th>
        <th style="width:70px">จำนวน</th>
        <th style="width:60px">หน่วย</th>
        <th style="width:110px">ราคาต่อหน่วย</th>
        <th style="width:80px">ส่วนลด%</th>
        <th style="width:60px">ภาษี</th>
        <th style="width:70px">หัก ณ ที่จ่าย</th>
        <th style="width:110px">มูลค่า</th>
        <th style="width:24px" class="no-print"></th>
      </tr>
    </thead>
    <tbody id="items-body">
    </tbody>
  </table>

  <div class="add-row-wrapper no-print">
    <button class="btn btn-orange" style="font-size:12px;padding:5px 12px;" onclick="addRow()">+ เพิ่มรายการ</button>
  </div>

  <!-- SUMMARY -->
  <div class="summary-section">
    <div>
      <div class="amount-in-words" id="amount-words">(ศูนย์บาทถ้วน)</div>
    </div>
    <table class="summary-table">
      <tr class="sub-row">
        <td>รวมเป็นเงิน</td>
        <td id="s-subtotal">0.00 บาท</td>
      </tr>
      <tr class="sub-row">
        <td>มูลค่าที่ไม่มี/ยกเว้นภาษี</td>
        <td id="s-exempt">0.00 บาท</td>
      </tr>
      <tr class="sub-row">
        <td>มูลค่าที่คำนวณภาษี</td>
        <td id="s-taxable">0.00 บาท</td>
      </tr>
      <tr class="sub-row">
        <td>ภาษีมูลค่าเพิ่ม</td>
        <td id="s-vat">0.00 บาท</td>
      </tr>
      <tr class="sub-row">
        <td>จำนวนเงินรวมทั้งสิ้น</td>
        <td id="s-total">0.00 บาท</td>
      </tr>
      <tr><td colspan="2" style="padding:4px 0"></td></tr>
      <tr class="sub-row">
        <td>หักภาษี ณ ที่จ่ายทั้งสิ้น</td>
        <td id="s-wht">0.00 บาท</td>
      </tr>
      <tr class="highlight-row">
        <td>ยอดจ่าย</td>
        <td id="s-grand">0.00 บาท</td>
      </tr>
    </table>
  </div>

  <div class="divider" style="margin-top:16px"></div>

  <!-- NOTES -->
  <div class="notes-section">
    <div class="notes-label">หมายเหตุ</div>
    <textarea class="notes-input" id="doc-notes" placeholder="หมายเหตุ : ..." rows="2"></textarea>
  </div>

  <!-- SIGNATURES -->
  <div class="sig-section">
    <div class="sig-block">
      <div class="sig-label">ในนาม</div>
      <input class="sig-name-input" id="sig-buyer-company" placeholder="ชื่อบริษัทลูกค้า">
      <div class="sig-line"></div>
      <input class="sig-name-input" id="sig-buyer-name" placeholder="ชื่อผู้สั่งซื้อสินค้า">
      <div class="sig-date-row">
        ผู้สั่งซื้อสินค้า &nbsp; วันที่ <input class="sig-date-input" id="sig-buyer-date" type="date">
      </div>
    </div>

    <div class="sig-block" style="text-align:center;">
      <div class="sig-company" id="sig-center-name"></div>
      <img id="sig-logo" class="sig-logo-center" style="display:none;" alt="Logo">
      <div style="font-size:11px;color:var(--gray);margin-top:4px;" id="sig-company-name-bot"></div>
    </div>

    <div class="sig-block">
      <div class="sig-label">ในนาม</div>
      <input class="sig-name-input" id="sig-seller-company" placeholder="ชื่อบริษัทผู้ขาย">
      <div class="sig-line"></div>
      <input class="sig-name-input" id="sig-seller-name" placeholder="ชื่อผู้อนุมัติ">
      <div class="sig-date-row">
        ผู้อนุมัติ &nbsp; วันที่ <input class="sig-date-input" id="sig-seller-date" type="date">
      </div>
    </div>
  </div>

  <div class="doc-footer">สร้างด้วยระบบใบเสนอราคาออนไลน์</div>

</div><!-- #document -->
</div><!-- .page-wrapper -->

<script>
// ====== THAI NUMBER TO TEXT ======
function bahtText(amount) {
  const digits = ['', 'หนึ่ง','สอง','สาม','สี่','ห้า','หก','เจ็ด','แปด','เก้า'];
  const positions = ['', 'สิบ','ร้อย','พัน','หมื่น','แสน','ล้าน'];
  amount = Math.round(amount * 100) / 100;
  if (amount === 0) return 'ศูนย์บาทถ้วน';
  let baht = Math.floor(amount);
  let satang = Math.round((amount - baht) * 100);
  function convert(n) {
    if (n === 0) return '';
    let str = '';
    const s = n.toString();
    const len = s.length;
    for (let i = 0; i < len; i++) {
      const d = parseInt(s[i]);
      const pos = len - i - 1;
      if (d === 0) continue;
      if (pos === 1 && d === 2) str += 'ยี่';
      else if (pos === 1 && d === 1) str += '';
      else str += digits[d];
      str += positions[pos];
    }
    return str;
  }
  // Handle millions
  function convertFull(n) {
    if (n === 0) return 'ศูนย์';
    let result = '';
    const millions = Math.floor(n / 1000000);
    const remainder = n % 1000000;
    if (millions > 0) result += convert(millions) + 'ล้าน';
    if (remainder > 0) result += convert(remainder);
    return result || 'ศูนย์';
  }
  let result = convertFull(baht) + 'บาท';
  if (satang > 0) result += convertFull(satang) + 'สตางค์';
  else result += 'ถ้วน';
  return result;
}

// ====== ROW MANAGEMENT ======
let rowCount = 0;

function addRow() {
  rowCount++;
  const tbody = document.getElementById('items-body');
  const tr = document.createElement('tr');
  tr.id = 'row-' + rowCount;
  tr.innerHTML = `
    <td class="seq-cell">${tbody.children.length + 1}</td>
    <td>
      <input class="cell-input" placeholder="รายละเอียดสินค้า/บริการ" oninput="calcRow(${rowCount})">
      <input class="cell-input" placeholder="รายละเอียดเพิ่มเติม (ถ้ามี)" style="font-size:11px;color:var(--gray);margin-top:2px;" oninput="calcRow(${rowCount})">
    </td>
    <td><input class="cell-input num" type="number" min="0" value="1" style="width:100%;text-align:right" oninput="calcRow(${rowCount})"></td>
    <td><input class="cell-input" value="ชิ้น" style="text-align:center"></td>
    <td><input class="cell-input num" type="number" min="0" value="0" style="width:100%;text-align:right" oninput="calcRow(${rowCount})"></td>
    <td><input class="cell-input num" type="number" min="0" max="100" value="0" style="width:100%;text-align:right" oninput="calcRow(${rowCount})"></td>
    <td>
      <select class="cell-select" onchange="calcRow(${rowCount});calcTotal()">
        <option value="7">7%</option>
        <option value="0">ยกเว้น</option>
        <option value="-1">ไม่มี</option>
      </select>
    </td>
    <td>
      <select class="cell-select" onchange="calcRow(${rowCount});calcTotal()">
        <option value="0">ไม่หัก</option>
        <option value="1">1%</option>
        <option value="2">2%</option>
        <option value="3">3%</option>
        <option value="5">5%</option>
      </select>
    </td>
    <td class="amount-cell" id="amt-${rowCount}">0.00</td>
    <td class="no-print"><button class="btn-del-row" onclick="deleteRow(${rowCount})">×</button></td>
  `;
  tbody.appendChild(tr);
  reindexRows();
  calcTotal();
}

function deleteRow(id) {
  const row = document.getElementById('row-' + id);
  if (row) row.remove();
  reindexRows();
  calcTotal();
}

function reindexRows() {
  const rows = document.querySelectorAll('#items-body tr');
  rows.forEach((tr, i) => {
    tr.querySelector('.seq-cell').textContent = i + 1;
  });
}

function calcRow(id) {
  const row = document.getElementById('row-' + id);
  if (!row) return;
  const inputs = row.querySelectorAll('input[type=number]');
  const qty = parseFloat(inputs[0].value) || 0;
  const price = parseFloat(inputs[1].value) || 0;
  const disc = parseFloat(inputs[2].value) || 0;
  const amount = qty * price * (1 - disc / 100);
  const cell = document.getElementById('amt-' + id);
  if (cell) cell.textContent = formatNum(amount);
  calcTotal();
}

function getRowData(tr) {
  const inputs = tr.querySelectorAll('input[type=number]');
  const selects = tr.querySelectorAll('select');
  const qty = parseFloat(inputs[0].value) || 0;
  const price = parseFloat(inputs[1].value) || 0;
  const disc = parseFloat(inputs[2].value) || 0;
  const vatType = selects[0] ? parseInt(selects[0].value) : 7;
  const whtRate = selects[1] ? parseInt(selects[1].value) : 0;
  const amount = qty * price * (1 - disc / 100);
  return { amount, vatType, whtRate };
}

function calcTotal() {
  const rows = document.querySelectorAll('#items-body tr');
  let subtotal = 0, exempt = 0, taxable = 0, vat = 0, wht = 0;
  rows.forEach(tr => {
    const d = getRowData(tr);
    subtotal += d.amount;
    if (d.vatType === -1) {
      exempt += d.amount;
    } else if (d.vatType === 0) {
      exempt += d.amount;
    } else {
      taxable += d.amount;
      vat += d.amount * 0.07;
    }
    wht += d.amount * d.whtRate / 100;
  });
  const total = subtotal + vat;
  const grand = total - wht;

  document.getElementById('s-subtotal').textContent = formatNum(subtotal) + ' บาท';
  document.getElementById('s-exempt').textContent = formatNum(exempt) + ' บาท';
  document.getElementById('s-taxable').textContent = formatNum(taxable) + ' บาท';
  document.getElementById('s-vat').textContent = formatNum(vat) + ' บาท';
  document.getElementById('s-total').textContent = formatNum(total) + ' บาท';
  document.getElementById('s-wht').textContent = formatNum(wht) + ' บาท';
  document.getElementById('s-grand').textContent = formatNum(grand) + ' บาท';
  document.getElementById('amount-words').innerHTML = '(<span>' + bahtText(grand) + '</span>)';
}

function formatNum(n) {
  return n.toLocaleString('th-TH', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}

// ====== LOGO ======
function uploadLogo(e) {
  const file = e.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = function(ev) {
    const dataUrl = ev.target.result;
    showLogo(dataUrl);
    localStorage.setItem('qt_logo', dataUrl);
  };
  reader.readAsDataURL(file);
}

function showLogo(dataUrl) {
  document.getElementById('logo-placeholder').style.display = 'none';
  const img = document.getElementById('logo-img');
  img.src = dataUrl;
  img.style.display = 'block';
  // Sig logo
  const sigLogo = document.getElementById('sig-logo');
  sigLogo.src = dataUrl;
  sigLogo.style.display = 'block';
}

// ====== LOCALSTORAGE ======
const COMPANY_KEYS = ['seller-name','seller-address','seller-tax','seller-phone'];
const DOC_KEYS = ['doc-no','doc-date','doc-ref','sales-name',
  'cust-name','cust-address','cust-sub','cust-dist','cust-tax','cust-phone','cust-email','cust-contact',
  'doc-notes','sig-buyer-company','sig-buyer-name','sig-buyer-date',
  'sig-seller-company','sig-seller-name','sig-seller-date'];

function saveCompany() {
  COMPANY_KEYS.forEach(k => {
    const el = document.getElementById(k);
    if (el) localStorage.setItem('qt_co_' + k, el.value);
  });
}

function loadCompany() {
  COMPANY_KEYS.forEach(k => {
    const el = document.getElementById(k);
    const val = localStorage.getItem('qt_co_' + k);
    if (el && val !== null) el.value = val;
  });
  const logo = localStorage.getItem('qt_logo');
  if (logo) showLogo(logo);
}

function saveDoc() {
  DOC_KEYS.forEach(k => {
    const el = document.getElementById(k);
    if (el) localStorage.setItem('qt_doc_' + k, el.value);
  });
  // Save rows
  const rows = document.querySelectorAll('#items-body tr');
  const rowData = [];
  rows.forEach(tr => {
    const inputs = tr.querySelectorAll('input');
    const selects = tr.querySelectorAll('select');
    rowData.push({
      desc: inputs[0] ? inputs[0].value : '',
      desc2: inputs[1] ? inputs[1].value : '',
      qty: inputs[2] ? inputs[2].value : '1',
      unit: inputs[3] ? inputs[3].value : 'ชิ้น',
      price: inputs[4] ? inputs[4].value : '0',
      disc: inputs[5] ? inputs[5].value : '0',
      vat: selects[0] ? selects[0].value : '7',
      wht: selects[1] ? selects[1].value : '0',
    });
  });
  localStorage.setItem('qt_rows', JSON.stringify(rowData));
}

function loadDoc() {
  DOC_KEYS.forEach(k => {
    const el = document.getElementById(k);
    const val = localStorage.getItem('qt_doc_' + k);
    if (el && val !== null) el.value = val;
  });
  // Load rows
  const savedRows = localStorage.getItem('qt_rows');
  if (savedRows) {
    const rowData = JSON.parse(savedRows);
    rowData.forEach(r => {
      addRow();
      const tbody = document.getElementById('items-body');
      const tr = tbody.lastElementChild;
      const inputs = tr.querySelectorAll('input');
      const selects = tr.querySelectorAll('select');
      if (inputs[0]) inputs[0].value = r.desc || '';
      if (inputs[1]) inputs[1].value = r.desc2 || '';
      if (inputs[2]) inputs[2].value = r.qty || '1';
      if (inputs[3]) inputs[3].value = r.unit || 'ชิ้น';
      if (inputs[4]) inputs[4].value = r.price || '0';
      if (inputs[5]) inputs[5].value = r.disc || '0';
      if (selects[0]) selects[0].value = r.vat || '7';
      if (selects[1]) selects[1].value = r.wht || '0';
      // calc
      const id = parseInt(tr.id.split('-')[1]);
      calcRow(id);
    });
  }
  calcTotal();
}

function clearForm() {
  if (!confirm('ล้างข้อมูลเอกสาร (ยกเว้นข้อมูลบริษัท)?')) return;
  DOC_KEYS.forEach(k => {
    const el = document.getElementById(k);
    if (el) el.value = '';
    localStorage.removeItem('qt_doc_' + k);
  });
  document.getElementById('items-body').innerHTML = '';
  rowCount = 0;
  localStorage.removeItem('qt_rows');
  // Auto generate doc no
  genDocNo();
  // Set today
  document.getElementById('doc-date').value = new Date().toISOString().split('T')[0];
  addRow();
  calcTotal();
}

function clearCompany() {
  if (!confirm('ล้างข้อมูลบริษัทผู้ขายทั้งหมด?')) return;
  COMPANY_KEYS.forEach(k => {
    const el = document.getElementById(k);
    if (el) el.value = '';
    localStorage.removeItem('qt_co_' + k);
  });
  localStorage.removeItem('qt_logo');
  document.getElementById('logo-placeholder').style.display = 'flex';
  document.getElementById('logo-img').style.display = 'none';
  document.getElementById('sig-logo').style.display = 'none';
}

// ====== AUTO SAVE ======
function setupAutoSave() {
  // Company fields
  COMPANY_KEYS.forEach(k => {
    const el = document.getElementById(k);
    if (el) el.addEventListener('input', saveCompany);
  });
  // Doc fields
  DOC_KEYS.forEach(k => {
    const el = document.getElementById(k);
    if (el) el.addEventListener('input', saveDoc);
  });
  // Sig center names sync
  document.getElementById('seller-name').addEventListener('input', function() {
    document.getElementById('sig-center-name').textContent = this.value;
    document.getElementById('sig-company-name-bot').textContent = this.value;
    saveCompany();
  });
}

// ====== DOC NUMBER GENERATOR ======
function genDocNo() {
  const now = new Date();
  const yy = now.getFullYear().toString();
  const mm = String(now.getMonth() + 1).padStart(2, '0');
  const dd = String(now.getDate()).padStart(2, '0');
  let seq = parseInt(localStorage.getItem('qt_seq') || '0') + 1;
  localStorage.setItem('qt_seq', seq);
  const docNo = 'QT' + yy + mm + dd + String(seq).padStart(3, '0');
  document.getElementById('doc-no').value = docNo;
}

// ====== SAVE PDF ======
function savePDF() {
  const noprint = document.querySelectorAll('.no-print');
  noprint.forEach(el => el.style.display = 'none');
  const element = document.getElementById('document');
  const opt = {
    margin: [8, 8, 8, 8],
    filename: (document.getElementById('doc-no').value || 'quotation') + '.pdf',
    image: { type: 'jpeg', quality: 0.98 },
    html2canvas: { scale: 2, useCORS: true },
    jsPDF: { unit: 'mm', format: 'a4', orientation: 'portrait' }
  };
  html2pdf().set(opt).from(element).save().then(() => {
    noprint.forEach(el => el.style.display = '');
  });
}

// ====== INIT ======
document.addEventListener('DOMContentLoaded', function() {
  setupAutoSave();
  loadCompany();

  // Sync sig center
  const sellerName = document.getElementById('seller-name').value;
  document.getElementById('sig-center-name').textContent = sellerName;
  document.getElementById('sig-company-name-bot').textContent = sellerName;

  const hasDocData = localStorage.getItem('qt_doc_doc-no');
  if (hasDocData) {
    loadDoc();
  } else {
    genDocNo();
    document.getElementById('doc-date').value = new Date().toISOString().split('T')[0];
    addRow();
    calcTotal();
  }

  // Observe table changes to auto-save rows
  const observer = new MutationObserver(() => saveDoc());
  observer.observe(document.getElementById('items-body'), { childList: true, subtree: true, characterData: true });

  // Save on any input in table
  document.getElementById('items-table').addEventListener('input', saveDoc);
  document.getElementById('items-table').addEventListener('change', saveDoc);
});
</script>
